<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ /public/$1 [L]
</IfModule>

# Block direct access to sensitive folders/files
RewriteRule ^(app|bootstrap|config|database|resources|routes|storage|vendor|tests|node_modules)/ - [F,L]
RewriteRule ^\.env$ - [F,L]
RewriteRule ^composer\.(json|lock)$ - [F,L]
RewriteRule ^\.git/ - [F,L]